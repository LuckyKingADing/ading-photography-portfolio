---
import BaseLayout from '../../components/BaseLayout.astro';
import { series, type PhotoSeries } from '../../data/series';
import { sitePath } from '../../utils/paths';

export function getStaticPaths() {
  return series.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

interface Props {
  item: PhotoSeries;
}

const { item } = Astro.props;
const currentIndex = series.findIndex((collection) => collection.slug === item.slug);
const nextSeries = series.length > 1 ? series[(currentIndex + 1) % series.length] : undefined;
---

<BaseLayout title={item.title} description={item.summary}>
  <article class="series-page">
    <header class="series-intro">
      <a class="back-link" href={`${sitePath()}#archive`}>← Archive</a>
      <p class="eyebrow">{item.location} / {item.category} / {item.date}</p>
      <h1>{item.title}</h1>
      <div class="series-copy">
        <p class="series-lead">{item.summary}</p>
        <p>{item.description}</p>
      </div>
    </header>

    <ol class="series-gallery" data-masonry aria-label={`“${item.title}”完整图集`}>
      {item.images.map((image, index) => (
        <li
          class:list={['series-photo', { 'series-photo-landscape': image.width > image.height }]}
          id={`photo-${index + 1}`}
        >
          <figure>
            <img
              src={sitePath(image.src)}
              alt={image.alt}
              width={image.width}
              height={image.height}
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : undefined}
              decoding="async"
            />
          </figure>
        </li>
      ))}
    </ol>

    <nav class="series-end" aria-label="作品集导航">
      <a href={`${sitePath()}#archive`}>Back to archive</a>
      {nextSeries && <a href={sitePath(`work/${nextSeries.slug}/`)}>Next: {nextSeries.title} →</a>}
    </nav>
  </article>
</BaseLayout>
