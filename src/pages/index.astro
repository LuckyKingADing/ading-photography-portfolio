---
import BaseLayout from '../components/BaseLayout.astro';
import { series } from '../data/series';
import { sitePath } from '../utils/paths';

const featuredPhotos = series
  .filter((collection) => collection.category === '人像')
  .flatMap((collection) =>
    collection.images
      .filter((image) => image.featuredOrder !== undefined)
      .map((image) => ({ collection, image })),
  )
  .sort((a, b) => (a.image.featuredOrder ?? 0) - (b.image.featuredOrder ?? 0));

---

<BaseLayout>
  <section class="home-intro" aria-labelledby="home-title">
    <p class="eyebrow">Personal photography</p>
    <h1 id="home-title">Places, light, and people worth remembering.</h1>
    <p class="intro-cn">关于旅行、人物和生活片段的个人摄影档案。</p>
  </section>

  <section class="featured-section" id="work" aria-labelledby="featured-title">
    <div class="section-heading">
      <h2 id="featured-title">Work</h2>
      <p>Selected Works</p>
    </div>

    <div class="featured-collage" data-masonry>
      {featuredPhotos.map(({ collection, image }, index) => (
        <a
          class="featured-item"
          href={sitePath(`work/${collection.slug}/`)}
          aria-label={`查看摄影系列“${collection.title}”：${image.alt}`}
        >
          <figure>
            <img
              src={sitePath(image.src)}
              alt={image.alt}
              width={image.width}
              height={image.height}
              loading={index === 0 ? 'eager' : 'lazy'}
              fetchpriority={index === 0 ? 'high' : undefined}
              decoding="async"
            />
          </figure>
        </a>
      ))}
    </div>
  </section>

  <section class="archive-section" id="archive" aria-labelledby="archive-title">
    <div class="section-heading">
      <h2 id="archive-title">Archive</h2>
      <p>Places &amp; series</p>
    </div>

    <div class="archive-list">
      {series.map((collection) => (
        <a class="archive-row" href={sitePath(`work/${collection.slug}/`)}>
          <span class="archive-meta">
            <span class="archive-location">{collection.location}</span>
            <span class="archive-category">{collection.category}</span>
          </span>
          <span class="archive-title">{collection.title}</span>
          <span class="archive-date">{collection.date}</span>
          <span class="archive-count">{String(collection.images.length).padStart(2, '0')} photos</span>
        </a>
      ))}
    </div>
  </section>

  <section class="about-section" id="about" aria-labelledby="about-title">
    <div>
      <p class="eyebrow">About</p>
      <h2 id="about-title">A personal archive, still growing.</h2>
    </div>
    <div class="about-copy">
      <p>ADING 持续记录旅行中的地点、自然光，以及人物不经意的状态。</p>
      <p>这里会随着新的拍摄慢慢生长。每个系列保留独立的时间、地点与观看节奏。</p>
    </div>
  </section>
</BaseLayout>
