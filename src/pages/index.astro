---
import BaseLayout from '../components/BaseLayout.astro';
import SeriesRow from '../components/SeriesRow.astro';
import { series } from '../data/series';
import { sitePath } from '../utils/paths';

const featured = series[0];
---

<BaseLayout current="home" surface="paper">
  <section class="home-hero" aria-labelledby="hero-title">
    <div class="hero-meta hero-meta-top">
      <span>精选作品</span>
      <span>{featured.year} — {featured.location}</span>
    </div>
    <h1 id="hero-title" class="hero-title">
      <span>凝视</span>
      <span>之间</span>
    </h1>
    <a class="hero-primary-frame" href={sitePath(`work/${featured.slug}/`)} aria-label={`查看精选系列“${featured.title}”`}>
      <img
        src={sitePath(featured.cover.src)}
        alt={featured.cover.alt}
        width={featured.cover.width}
        height={featured.cover.height}
        loading="eager"
        fetchpriority="high"
      />
    </a>
    <div class="hero-secondary-frame" aria-hidden="true">
      <img
        src={sitePath(featured.secondaryCover.src)}
        alt=""
        width={featured.secondaryCover.width}
        height={featured.secondaryCover.height}
        loading="eager"
      />
    </div>
    <div class="hero-meta hero-meta-bottom">
      <span>当前系列 / 01</span>
      <a href={sitePath(`work/${featured.slug}/`)}>查看“{featured.title}” <span aria-hidden="true">↗</span></a>
    </div>
  </section>

  <section class="selected-series" id="selected-series" aria-labelledby="selected-series-title">
    <div class="section-heading">
      <p id="selected-series-title">精选系列</p>
      <p>人像 / 地点 / 记忆</p>
    </div>
    <div class="series-list">
      {series.map((item, index) => <SeriesRow item={item} index={index} />)}
    </div>
  </section>

  <section class="home-statement" aria-label="摄影创作方式">
    <p class="eyebrow">关于创作</p>
    <p>让自然光、无防备的动作，以及人物周围的气息共同形成照片。</p>
    <a class="text-link" href={sitePath('about/')}>了解 ADING <span aria-hidden="true">↗</span></a>
  </section>
</BaseLayout>
